# =============================================================================
# Agent-fleet configuration. Copy to a real env file (NOT committed — see .gitignore)
# and fill in your own values. Secrets should come from a secret store at deploy time.
#
#   dispatcher VM:  /etc/agent/dispatcher.env   (loaded by the systemd unit)
#   MCP servers:    values are read by agent.mcp.json via ${VAR:-default} expansion,
#                   so export them in the dispatcher/worker environment too.
# =============================================================================

# ---- Linear (the queue) -----------------------------------------------------
LINEAR_API_KEY=                       # Linear API key for the agent identity (secret)
LINEAR_TEAM_KEY=ENG                   # your Linear team key, e.g. ENG
AGENT_LINEAR_USER_ID=                 # the agent's Linear user id (claims/assigns issues)

# Workflow status ids — create "AI Ready" + "AI Blocked" in your team workflow, then paste each id.
# All four are REQUIRED; the dispatcher refuses to start without them.
STATUS_AI_READY=                      # entry gate (human-promoted)
STATUS_IN_PROGRESS=                   # claimed / working
STATUS_AI_REVIEW=                     # success exit gate (human review)
STATUS_AI_BLOCKED=                    # escalation

# ---- Dispatcher loop --------------------------------------------------------
AGENT_CONCURRENCY=1                   # start at 1; raise once trusted
AGENT_POLL_INTERVAL_SEC=60
AGENT_LEASE_MINUTES=30                # In Progress idle > this → swept to AI Blocked
AGENT_WORKER_TIMEOUT_SEC=3600
AGENT_KEEP_WORKTREES=1

# ---- Worker / paths ---------------------------------------------------------
AGENT_RUN_USER=agent                  # low-priv unix user the worker runs as
AGENT_RUN_HOME=/home/agent
AGENT_REPO=/home/agent/app            # the app repo clone the worker builds worktrees from
AGENT_WORKTREE_BASE=/home/agent/agent-wt
AGENT_FLEET_REPO=/home/agent/agent_fleet
AGENT_FLEET_DIR=/home/agent/agent_fleet   # used by agent.mcp.json to locate the MCP scripts
CLAUDE_BIN=/home/agent/.npm-global/bin/claude
AGENT_MODEL=claude-opus-4-8

# ---- Notifications (Resend) -------------------------------------------------
RESEND_API_KEY=                       # optional; emails are best-effort
AGENT_NOTIFY_EMAIL=you@example.com
AGENT_NOTIFY_FROM=Agent <agent@example.com>   # a verified Resend sender domain

# ---- AWS (scoped agent role) ------------------------------------------------
AWS_PROFILE=agent                     # profile that assumes the scoped agent role
AWS_REGION=us-east-1

# ---- agent-rds MCP (prod read-only / staging read-write) --------------------
APP_REPO=/home/agent/app              # app checkout that holds the staging SQL helper
AGENT_RDS_HELPER=scripts/rdsql.sh     # relative path of that helper inside APP_REPO
AGENT_DB_TARGETS=app                  # comma-separated logical DB/schema names
PROD_RDS_HOST_PATTERN={svc}.CHANGEME.us-east-1.rds.amazonaws.com   # "{svc}" -> target name
PROD_RO_USER=agent_ro                 # SELECT-only DB user for the prod read path
PROD_RO_PASSWORD=                     # its password (or use PROD_RO_ENV_FILE below — keep out of git)
PROD_RO_ENV_FILE=/etc/agent/prod-ro.env
AGENT_TENANT_HINT=                    # optional tenant/account id surfaced in the tool description

# ---- eks-staging MCP (staging-only Kubernetes) ------------------------------
EKS_CLUSTER=my-cluster
STAGING_NAMESPACE=staging             # the ONE namespace this tool may touch (fixed per deploy)
STAGING_SERVICES=app                  # space-separated deployments woken by `wake`

# ---- github MCP (scoped App identity) ---------------------------------------
GH_REPO=your-org/your-app
GH_STAGING_BRANCH=staging             # deploy-on-merge staging branch
GH_APP_ID=                            # agent GitHub App id
GH_APP_INSTALLATION_ID=               # its installation id on the repo
GH_APP_KEY_FILE=/etc/agent/gh-app-key.pem   # App private key (.pem), 0600, never in git
